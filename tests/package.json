{
  "name": "chess-test-harness",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright test harness (unit, integration, e2e) for the Temporal + Supabase chess app.",
  "scripts": {
    "test": "node node_modules/@playwright/test/cli.js test",
    "test:unit": "node node_modules/@playwright/test/cli.js test --project=unit",
    "test:integration": "node node_modules/@playwright/test/cli.js test --project=integration",
    "test:e2e": "node node_modules/@playwright/test/cli.js test --project=e2e",
    "report": "node node_modules/@playwright/test/cli.js show-report",
    "install:browsers": "node node_modules/@playwright/test/cli.js install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2"
  }
}
